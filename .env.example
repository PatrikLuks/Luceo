# Luceo environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
# DATABASE_URL=postgresql://user:password@localhost:5432/luceo

# === App Config ===
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=info

# === Database ===
POSTGRES_USER=luceo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=luceo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Auth / JWT ===
JWT_SECRET=changeme-generate-a-real-secret
JWT_EXPIRATION_HOURS=24

# === GDPR / Privacy ===
# EU region only — required for GDPR compliance
DATA_REGION=eu-central
ENCRYPTION_KEY=changeme-generate-a-real-key

# === CORS (production only) ===
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://luceo.app
